# ============================================================
# RistoSaaS — Variabili d'ambiente
# Copia in .env.local e compila i valori
# ============================================================

# ---------- Applicazione ----------
NEXT_PUBLIC_APP_NAME=RistoSaaS
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_LOCALE=it-IT
NEXT_PUBLIC_TIMEZONE=Europe/Rome
NEXT_PUBLIC_PRODUCT_PLAN=all_included
NEXT_PUBLIC_TENANT_ID=tenant_demo
NEXT_PUBLIC_TENANT_NAME="RistoSaaS Demo"

# ---------- Database / PostgreSQL ----------
DATABASE_URL=postgresql://user:password@host:5432/ristosaas?schema=public

# ---------- Auth / JWT ----------
AUTH_SECRET=your-secret-key-change-me
JWT_SECRET=replace-with-a-long-random-secret
SESSION_MAX_AGE_SECONDS=86400
SESSION_MAX_AGE_SUPERVISOR_SECONDS=43200
SESSION_MAX_AGE_SUPERADMIN_SECONDS=28800
REFRESH_MAX_AGE_SECONDS=1209600
AUTH_SESSION_DURATION_HOURS=24
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=5

# ---------- Licenza ----------
LICENSE_KEY=
LICENSE_ENDPOINT=https://api.ristosaas.it/license/validate
LICENSE_CHECK_INTERVAL_HOURS=24

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id
STRIPE_PRICE_RESTAURANT_MONTHLY=price_restaurant_monthly_id
STRIPE_PRICE_RESTAURANT_ANNUAL=price_restaurant_annual_id
STRIPE_PRICE_HOTEL_MONTHLY=price_hotel_monthly_id
STRIPE_PRICE_HOTEL_ANNUAL=price_hotel_annual_id
STRIPE_PRICE_ALL_INCLUDED_MONTHLY=price_all_included_monthly_id
STRIPE_PRICE_ALL_INCLUDED_ANNUAL=price_all_included_annual_id
STRIPE_SEATS_RESTAURANT=15
STRIPE_SEATS_HOTEL=15
STRIPE_SEATS_ALL_INCLUDED=25
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/stripe
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/stripe?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/stripe?checkout=cancel
NEXT_PUBLIC_STRIPE_PORTAL_URL=https://billing.stripe.com/session

# ---------- SMTP / Email ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ristosaas.it
SMTP_PASS=
SMTP_FROM="RistoSaaS <noreply@ristosaas.it>"
SMTP_SECURE=false

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7
AI_SCHEDULER_TOKEN=replace-with-a-strong-random-token

# ---------- WebSocket ----------
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_PORT=3001
WS_HEARTBEAT_INTERVAL_MS=30000

# ---------- Stampanti / Hardware ----------
PRINTER_KDS_IP=192.168.1.100
PRINTER_CASSA_IP=192.168.1.101
PRINTER_BAR_IP=192.168.1.102
PRINTER_PIZZERIA_IP=192.168.1.103
PRINTER_DRIVER=escpos
PRINTER_PAPER_WIDTH=80

# ---------- Gestione Sala ----------
NEXT_PUBLIC_DEFAULT_TABLES=20
NEXT_PUBLIC_TABLE_SECTIONS=Sala,Terrazza,Privé
NEXT_PUBLIC_MAX_COVERS=200

# ---------- QR Tavoli ----------
NEXT_PUBLIC_QR_BASE_URL=https://qr.ristosaas.it
NEXT_PUBLIC_QR_LOGO_URL=/logo-qr.png

# ---------- Magazzino ----------
LOW_STOCK_THRESHOLD_PERCENT=15
STOCK_ALERT_EMAIL=magazzino@ristosaas.it

# ---------- Prenotazioni ----------
NEXT_PUBLIC_BOOKING_SLOTS_START=12:00
NEXT_PUBLIC_BOOKING_SLOTS_END=23:00
NEXT_PUBLIC_BOOKING_SLOT_DURATION_MIN=30
NEXT_PUBLIC_MAX_PARTY_SIZE=20

# ---------- Catering ----------
CATERING_MIN_GUESTS=10
CATERING_DEPOSIT_PERCENT=30

# ---------- Report / Export ----------
REPORT_EXPORT_FORMAT=xlsx
REPORT_RETENTION_DAYS=365
REPORT_TIMEZONE=Europe/Rome

# ---------- i18n ----------
NEXT_PUBLIC_DEFAULT_LANG=it
NEXT_PUBLIC_SUPPORTED_LANGS=it,en

# ---------- Super Admin ----------
SUPER_ADMIN_EMAIL=admin@ristosaas.it
SUPER_ADMIN_TOKEN=
SEED_SUPERADMIN_PASSWORD=replace-with-a-strong-superadmin-seed-password

# ---------- Dev / Debug ----------
DEV_ACCESS_TOKEN=dev-secret-token
DEV_BRIDGE_ENABLED=false
NEXT_PUBLIC_DEBUG_MODE=false
LOG_LEVEL=info
SENTRY_ENABLED=false
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_COOLDOWN_SECONDS=300

# ---------- Manutenzione ----------
MAINTENANCE_MODE=false
MAINTENANCE_ALLOWED_IPS=127.0.0.1

# ---------- Tenant / Multi-tenant ----------
TENANT_ID=
TENANT_SLUG=
TENANT_PLAN=pro

# ---------- Integrazione GS (Gestione Totale) ----------
GS_API_URL=
GS_API_KEY=
GS_SYNC_INTERVAL_MINUTES=15

# ---------- Sicurezza ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSP_REPORT_URI=
