generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductPlan {
  restaurant_only
  hotel_only
  all_included
}

enum CustomerType {
  vip
  habitue
  walk_in
  new
}

enum LicenseStatus {
  trial
  active
  expired
  suspended
}

enum TenantAccessStatus {
  active
  blocked
}

enum StaffStatus {
  attivo
  ferie
  malattia
  licenziato
}

enum BookingStatus {
  confermata
  in_attesa
  annullata
  completata
}

enum CateringStatus {
  preventivo
  confermato
  completato
  annullato
}

enum TakeawayOrderStatus {
  nuovo
  in_preparazione
  pronto
  ritirato
  consegnato
  annullato
}

enum TakeawayOrderType {
  asporto
  delivery
}

enum ArchivedOrderStatus {
  completato
  annullato
  stornato
}

enum ArchivedPaymentMethod {
  contanti
  carta
  misto
}

enum RestaurantTableShape {
  tondo
  quadrato
}

enum RestaurantTableStatus {
  libero
  aperto
  conto
  sporco
}

enum TenantFeatureCode {
  restaurant
  hotel
  integration_room_charge
  integration_unified_folio
  integration_meal_plans
}

enum RestaurantOrderStatus {
  pending
  in_attesa
  in_preparazione
  pronto
  servito
  chiuso
  annullato
}

enum RestaurantOrderOnlinePaymentStatus {
  unpaid
  paid
}

enum HotelReservationStatus {
  confermata
  in_casa
  check_out
  cancellata
  no_show
}

enum HotelRoomStatus {
  libera
  occupata
  da_pulire
  pulita
  fuori_servizio
  manutenzione
}

enum BoardType {
  room_only
  bed_breakfast
  half_board
  full_board
}

enum FolioStatus {
  open
  closed
}

enum FolioChargeSource {
  hotel
  restaurant
  manual
  city_tax
  payment
  meal_plan_credit
  room_service
}

enum RoomServiceCategory {
  food
  laundry
  minibar
  shoe_cleaning
  linen
  amenities
  transport
  other
}

enum RoomServiceStatus {
  pending
  in_preparation
  out_for_delivery
  delivered
  cancelled
}

enum KeycardStatus {
  attiva
  scaduta
  annullata
}

enum WarehouseMovementType {
  carico
  scarico
  scarico_comanda
  trasferimento
  rettifica
}

enum AiProposalType {
  food_cost
  warehouse
  menu
  pricing
  manager_report
  reorder
  hotel_bridge
}

enum AiProposalStatus {
  draft
  pending_review
  approved
  rejected
  applied
  cancelled
}

enum RestaurantOrderArea {
  sala
  cucina
  bar
  pizzeria
}

model Tenant {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  plan         ProductPlan
  accessStatus TenantAccessStatus  @default(active)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  features    TenantFeature[]
  users       User[]
  customers   Customer[]
  license    TenantLicense?
  emailConfig TenantEmailConfig?
  hotelRatePlans HotelRatePlan[]
  hotelRooms  HotelRoom[]
  reservations HotelReservation[]
  stays       Stay[]
  folios      GuestFolio[]
  housekeepingTasks HousekeepingTask[]
  keycards    HotelKeycard[]
  warehouseItems WarehouseItem[]
  warehouseMovements WarehouseMovement[]
  warehouseEquipments WarehouseEquipment[]
  warehouseLots WarehouseLot[]
  warehouseCostHistory WarehouseCostHistory[]
  warehouseLocationStocks WarehouseLocationStock[]
  operationalNotes OperationalNote[]
  shiftPlans ShiftPlan[]
  aiChatLogs  AiChatLog[]
  aiProposals AiProposal[]
  recipes     Recipe[]
  menuItems   MenuItem[]
  dailyDishes DailyDish[]
  restaurantOrders RestaurantOrder[]
  dailyClosureReports DailyClosureReport[]
  staffMembers StaffMember[]
  bookings Booking[]
  suppliers Supplier[]
  cateringEvents CateringEvent[]
  takeawayOrders TakeawayOrder[]
  archivedOrders ArchivedOrder[]
  restaurantRooms RestaurantRoom[]
  restaurantTables RestaurantTable[]
  staffShifts StaffShift[]
  billingSubscriptions BillingSubscription[]
  billingEvents BillingEvent[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  archivedSupplierOrders ArchivedSupplierOrder[]
  haccpEntries HaccpEntry[]
  hardwareDevices HardwareDevice[]
  printRoutes PrintRoute[]
  supervisorStorni SupervisorStorno[]
  warehouseVoiceLogs WarehouseVoiceLog[]
  archivioFiscalStubs      ArchivioFiscalStub[]
  notifications            Notification[]
  roomServiceOrders        RoomServiceOrder[]
  roomServiceCatalogItems  RoomServiceCatalogItem[]
}

model BillingSubscription {
  id                   String   @id @default(cuid())
  tenantId             String
  stripeCustomerId     String?
  stripeSubscriptionId String   @unique
  priceId              String?
  status               String
  cancelAtPeriodEnd    Boolean  @default(false)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model BillingEvent {
  id            String   @id @default(cuid())
  tenantId      String?
  stripeEventId String   @unique
  type          String
  status        String
  payload       Json
  createdAt     DateTime @default(now())
  processedAt   DateTime?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, type])
  @@index([createdAt])
}

model PlatformConfig {
  id               String   @id
  maintenanceMode  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  actorId    String
  actorRole  String
  actorEmail String?
  action     String
  tenantId   String?
  targetId   String?
  metadata   Json?
  ipAddress  String?

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([action, createdAt])
}

model RateLimitHit {
  id        BigInt   @id @default(autoincrement())
  bucket    String
  keyHash   String
  createdAt DateTime @default(now())

  @@index([bucket, keyHash, createdAt])
  @@index([createdAt])
}

model TenantFeature {
  id       String            @id @default(cuid())
  tenantId String
  code     TenantFeatureCode
  enabled  Boolean           @default(true)
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  username     String   @unique
  passwordHash String
  name         String
  email        String   @unique
  role         String
  sessionVersion Int @default(0)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     UserSession[]
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String?
  jti        String    @unique
  tokenType  String    @default("access")
  userAgent  String?
  ipAddress  String?
  issuedAt   DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  revokedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([tenantId, revokedAt])
  @@index([expiresAt])
}

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  email       String?
  phone       String?
  type        CustomerType @default(new)
  visits      Int @default(0)
  totalSpent  Decimal @db.Decimal(10, 2) @default(0)
  avgSpend    Decimal @db.Decimal(10, 2) @default(0)
  lastVisit   DateTime?
  allergies   String?
  preferences String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations HotelReservation[]
  folios      GuestFolio[]
}

model TenantLicense {
  id           String        @id @default(cuid())
  tenantId     String        @unique
  licenseKey   String        @unique
  status       LicenseStatus @default(active)
  plan         ProductPlan
  billingCycle String
  seats        Int
  usedSeats    Int
  activatedAt  DateTime
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantEmailConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  host           String
  port           Int
  username       String
  password       String
  fromAddress    String
  secure         Boolean  @default(false)
  lastTestStatus String?
  lastTestedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HotelRoom {
  id                  String          @id @default(cuid())
  tenantId            String
  code                 String
  floor                Int
  roomType             String
  capacity             Int
  status               HotelRoomStatus
  ratePlanCode         String?
  /// Tariffa pubblicabile per notte (listino camera); usata in prenotazioni / booking interno.
  defaultNightlyRate   Decimal         @db.Decimal(10, 2) @default(0)
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations HotelReservation[]
  tasks        HousekeepingTask[]
  keycards     HotelKeycard[]

  @@unique([tenantId, code])
}

model HotelRatePlan {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  roomType    String
  boardType   BoardType
  nightlyRate Decimal  @db.Decimal(10, 2)
  refundable  Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, roomType, active])
}

model HotelReservation {
  id           String                @id @default(cuid())
  tenantId     String
  customerId   String
  roomId       String?
  guestName    String
  phone        String?
  email        String?
  checkInDate  DateTime
  checkOutDate DateTime
  guests       Int
  status       HotelReservationStatus
  roomType     String
  boardType    BoardType
  nights       Int
  rate         Decimal               @db.Decimal(10, 2)
  documentCode String?
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  room         HotelRoom?            @relation(fields: [roomId], references: [id], onDelete: SetNull)
  stay         Stay?
  keycards     HotelKeycard[]
}

model Stay {
  id               String             @id @default(cuid())
  tenantId         String
  reservationId    String             @unique
  actualCheckInAt  DateTime?
  actualCheckOutAt DateTime?
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation      HotelReservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  folio            GuestFolio?
}

model HousekeepingTask {
  id               String   @id @default(cuid())
  tenantId         String
  roomId           String
  assignedToUserId String?
  status           String
  scheduledFor     DateTime
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room             HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model GuestFolio {
  id         String       @id @default(cuid())
  tenantId   String
  customerId String
  stayId     String?      @unique
  currency   String       @default("EUR")
  balance    Decimal      @db.Decimal(10, 2)
  status     FolioStatus  @default(open)
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  stay       Stay?        @relation(fields: [stayId], references: [id], onDelete: SetNull)
  charges     FolioCharge[]
}

model FolioCharge {
  id          String            @id @default(cuid())
  folioId     String
  source      FolioChargeSource
  sourceId    String?
  description String
  amount      Decimal           @db.Decimal(10, 2)
  postedAt    DateTime          @default(now())
  folio       GuestFolio        @relation(fields: [folioId], references: [id], onDelete: Cascade)
}

model HotelKeycard {
  id            String           @id @default(cuid())
  tenantId      String
  roomId        String
  reservationId String
  validFrom     DateTime
  validUntil    DateTime
  status        KeycardStatus
  issuedBy      String
  createdAt     DateTime         @default(now())
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room          HotelRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reservation   HotelReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([tenantId, reservationId])
  @@index([tenantId, roomId])
}

model WarehouseItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String
  qty         Decimal  @db.Decimal(12, 3)
  unit        String
  minStock    Decimal  @db.Decimal(12, 3)
  costPerUnit Decimal  @db.Decimal(12, 4)
  supplier    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements       WarehouseMovement[]
  lots            WarehouseLot[]
  costHistory     WarehouseCostHistory[]
  recipeIngredients RecipeIngredient[]
  purchaseOrderItems PurchaseOrderItem[]
  locationStocks  WarehouseLocationStock[]

  @@unique([tenantId, name])
}

model WarehouseMovement {
  id              String                @id @default(cuid())
  tenantId        String
  warehouseItemId String
  date            DateTime
  type            WarehouseMovementType
  qty             Decimal               @db.Decimal(12, 3)
  unit            String
  reason          String
  fromLocation    String?
  toLocation      String?
  note            String?
  orderId         String?
  createdAt       DateTime              @default(now())
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            WarehouseItem         @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

model WarehouseLocationStock {
  id              String        @id @default(cuid())
  tenantId        String
  warehouseItemId String
  location        String
  qty             Decimal       @db.Decimal(12, 3) @default(0)
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, warehouseItemId, location])
  @@index([tenantId, location])
  @@index([tenantId, warehouseItemId])
}

model OperationalNote {
  id        String   @id @default(cuid())
  tenantId  String
  area      String
  text      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, area])
}

model ShiftPlan {
  id          String       @id @default(cuid())
  tenantId    String
  area        String       @default("cucina")
  day         String
  staffName   String
  staffId     String?
  startTime   String       @default("")
  endTime     String       @default("")
  hours       String       @default("")
  role        String       @default("")
  shiftType   String       @default("lavoro")
  notes       String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([tenantId, area])
  @@index([tenantId, day])
  @@index([tenantId, staffId])
}

model WarehouseEquipment {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  category  String
  qty       Int
  status    String
  location  String
  value     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@unique([tenantId, name, location])
}

model AiChatLog {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  context          String
  userMessage      String
  assistantMessage String?
  errorMessage     String?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
}

model AiProposal {
  id           String           @id @default(cuid())
  tenantId     String
  createdBy    String
  type         AiProposalType
  status       AiProposalStatus @default(draft)
  title        String
  summary      String
  payload      Json
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNotes  String?
  appliedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, type, createdAt])
}

model WarehouseLot {
  id              String   @id @default(cuid())
  tenantId        String
  warehouseItemId String
  lotCode         String
  qty             Decimal  @db.Decimal(12, 3)
  qtyRemaining    Decimal  @db.Decimal(12, 3)
  purchaseUnitCost Decimal @db.Decimal(12, 4)
  receivedAt      DateTime
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, expiresAt])
  @@index([tenantId, warehouseItemId, receivedAt])
  @@unique([tenantId, warehouseItemId, lotCode])
}

model WarehouseCostHistory {
  id              String   @id @default(cuid())
  tenantId        String
  warehouseItemId String
  unitCost        Decimal  @db.Decimal(12, 4)
  source          String
  effectiveAt     DateTime
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, warehouseItemId, effectiveAt])
}

model Recipe {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  category       String
  area           RestaurantOrderArea
  portions       Int
  sellingPrice   Decimal  @db.Decimal(10, 2)
  targetFcPct    Decimal  @db.Decimal(5, 2)
  ivaPct         Decimal  @db.Decimal(5, 2)
  overheadPct    Decimal  @db.Decimal(5, 2)
  packagingCost  Decimal  @db.Decimal(10, 2)
  laborCost      Decimal  @db.Decimal(10, 2)
  energyCost     Decimal  @db.Decimal(10, 2)
  notes          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredients    RecipeIngredient[]
  steps          RecipeStep[]
  menuItems      MenuItem[]
  dailyDishes    DailyDish[]

  @@unique([tenantId, name])
}

model RecipeIngredient {
  id        String   @id @default(cuid())
  recipeId  String
  warehouseItemId String?
  name      String
  qty       Decimal  @db.Decimal(12, 3)
  unit      String
  unitCost  Decimal  @db.Decimal(12, 4)
  wastePct  Decimal  @db.Decimal(5, 2)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  warehouseItem WarehouseItem? @relation(fields: [warehouseItemId], references: [id], onDelete: SetNull)
}

model RecipeStep {
  id        String   @id @default(cuid())
  recipeId  String
  stepOrder Int
  text      String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String
  area        String
  price       Decimal  @db.Decimal(10, 2)
  code        String
  active      Boolean
  recipeId    String?
  notes       String
  foodCostPct Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipe      Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  restaurantOrderItems RestaurantOrderItem[]
}

model DailyDish {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  allergens   String
  recipeId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipe      Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model RestaurantOrder {
  id           String                @id @default(cuid())
  tenantId     String
  table        String?
  covers       Int?
  area         RestaurantOrderArea
  waiter       String
  notes        String
  activeCourse Int
  courseStates Json
  status       RestaurantOrderStatus
  /** Pagamento online (Stripe Checkout) per ordini da menu pubblico. */
  onlinePaymentStatus     RestaurantOrderOnlinePaymentStatus @default(unpaid)
  stripeCheckoutSessionId String?                            @unique
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items        RestaurantOrderItem[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, table, createdAt])
}

model RestaurantOrderItem {
  id        String              @id @default(cuid())
  orderId   String
  menuItemId String?
  name      String
  qty       Int
  category  String?
  area      RestaurantOrderArea
  price     Decimal?            @db.Decimal(10, 2)
  note      String?
  course    Int
  order     RestaurantOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem  MenuItem?           @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId, area])
}

model DailyClosureReport {
  id         String   @id @default(cuid())
  tenantId   String
  date       DateTime
  foodSpend  Decimal  @db.Decimal(10, 2)
  staffSpend Decimal  @db.Decimal(10, 2)
  revenue    Decimal  @db.Decimal(10, 2)
  notes      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

model StaffMember {
  id         String      @id @default(cuid())
  tenantId   String
  name       String
  role       String
  email      String
  phone      String
  hireDate   DateTime
  salary     Decimal     @db.Decimal(10, 2)
  status     StaffStatus
  hoursWeek  Int
  notes      String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts     StaffShift[]
  shiftPlans ShiftPlan[]
}

model StaffShift {
  id          String      @id @default(cuid())
  tenantId    String
  staffId     String
  clockInAt   DateTime
  clockOutAt  DateTime?
  notes       String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId, clockInAt])
}

model Booking {
  id           String        @id @default(cuid())
  tenantId     String
  customerName String
  phone        String
  email        String
  date         DateTime
  time         String
  guests       Int
  table        String
  notes        String
  status       BookingStatus
  allergies    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Supplier {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  category     String
  email        String
  phone        String
  address      String
  piva         String
  paymentTerms String
  rating       Int
  notes        String
  active       Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
}

model CateringEvent {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  date        DateTime
  guests      Int
  venue       String
  budget      Decimal        @db.Decimal(10, 2)
  status      CateringStatus
  contact     String
  phone       String
  menu        String
  notes       String
  depositPaid Boolean
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TakeawayOrder {
  id           String              @id @default(cuid())
  tenantId     String
  customerName String
  phone        String
  items        Json
  total        Decimal             @db.Decimal(10, 2)
  status       TakeawayOrderStatus
  pickupTime   String
  notes        String
  type         TakeawayOrderType
  address      String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ArchivedOrder {
  id            String                @id @default(cuid())
  tenantId      String
  sourceOrderId String?               @unique
  date          DateTime
  table         String
  waiter        String
  items         Json
  total         Decimal               @db.Decimal(10, 2)
  status        ArchivedOrderStatus
  paymentMethod ArchivedPaymentMethod
  closedAt      DateTime
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, closedAt])
}

model RestaurantRoom {
  id        String            @id @default(cuid())
  tenantId  String
  name      String
  tables    Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTables RestaurantTable[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model RestaurantTable {
  id        String               @id @default(cuid())
  tenantId  String
  roomId    String
  nome      String
  posti     Int
  x         Int
  y         Int
  forma     RestaurantTableShape
  stato     RestaurantTableStatus
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room      RestaurantRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([tenantId, roomId])
}

enum PurchaseOrderStatus {
  bozza
  inviato
  parziale
  ricevuto
  annullato
}

/// Registro archivio documenti ordine fornitore (conferma bozza vs ordine emesso).
enum ArchivedSupplierOrderKind {
  bozza_confermata
  ordine_confermato
}

model PurchaseOrder {
  id              String               @id @default(cuid())
  tenantId        String
  supplierId      String
  code            String
  status          PurchaseOrderStatus  @default(bozza)
  notes           String               @default("")
  orderedAt       DateTime             @default(now())
  expectedAt      DateTime?
  receivedAt      DateTime?
  total           Decimal              @db.Decimal(12, 2) @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items           PurchaseOrderItem[]
  archivedSupplierOrder ArchivedSupplierOrder?

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
}

model ArchivedSupplierOrder {
  id               String                     @id @default(cuid())
  tenantId         String
  purchaseOrderId  String                     @unique
  code             String
  supplierId       String
  supplierName     String
  poStatus         PurchaseOrderStatus
  kind             ArchivedSupplierOrderKind
  total            Decimal                    @db.Decimal(12, 2)
  orderedAt        DateTime?
  notes            String                     @default("")
  archivedAt       DateTime                   @default(now())
  tenant           Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder    PurchaseOrder              @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, archivedAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  warehouseItemId String
  qtyOrdered      Decimal       @db.Decimal(12, 3)
  qtyReceived     Decimal       @db.Decimal(12, 3) @default(0)
  unit            String
  unitCost        Decimal       @db.Decimal(12, 4)
  notes           String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order           PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  warehouseItem   WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Restrict)

  @@index([tenantId, purchaseOrderId])
  @@index([tenantId, warehouseItemId])
}

enum HaccpEntryType {
  temp_frigo
  temp_freezer
  temp_cottura
  temp_abbattitore
  sanificazione
  ricezione_merce
  altro
}

model HaccpEntry {
  id         String          @id @default(cuid())
  tenantId   String
  type       HaccpEntryType  @default(temp_frigo)
  recordedAt DateTime        @default(now())
  location   String          @default("")
  tempC      Decimal?        @db.Decimal(5, 2)
  operator   String          @default("")
  notes      String          @default("")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, recordedAt])
  @@index([tenantId, type, recordedAt])
}

enum HardwareDeviceType {
  stampante_termica
  stampante_fiscale
  display_kds
  lettore_keycard
  cassetto_denaro
  altro
}

enum HardwareDeviceConnection {
  tcp_ip
  usb
  bluetooth
  hdmi
  altro
}

enum HardwareDeviceStatus {
  online
  offline
  manutenzione
}

enum HardwareDepartment {
  cucina
  pizzeria
  bar
  cassa
  sala
  reception
  housekeeping
  magazzino
  altro
}

model HardwareDevice {
  id         String                    @id @default(cuid())
  tenantId   String
  name       String
  type       HardwareDeviceType        @default(stampante_termica)
  department HardwareDepartment        @default(cucina)
  connection HardwareDeviceConnection  @default(tcp_ip)
  ipAddress  String?
  port       Int?
  status     HardwareDeviceStatus      @default(offline)
  notes      String                    @default("")
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  tenant     Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routes     PrintRoute[]              @relation("DeviceRoutes")

  @@unique([tenantId, name])
  @@index([tenantId, department])
  @@index([tenantId, status])
}

enum PrintRouteEvent {
  nuova_comanda
  ordine_bevande
  chiusura_conto
  preconto
  nota_cucina
  keycard_emessa
}

model PrintRoute {
  id         String             @id @default(cuid())
  tenantId   String
  event      PrintRouteEvent
  department HardwareDepartment
  deviceId   String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device     HardwareDevice     @relation("DeviceRoutes", fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, event, department])
  @@index([tenantId, department])
  @@index([tenantId, deviceId])
}

/// Registro storni / aggiustamenti incasso lato supervisor (non sostituisce documentazione fiscale).
model SupervisorStorno {
  id        String   @id @default(cuid())
  tenantId  String
  amount    Decimal  @db.Decimal(12, 2)
  motivo    String
  tavolo    String   @default("")
  ordineId  String   @default("")
  note      String   @default("")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

/// Traccia comandi vocali magazzino (testo grezzo) per audit interno.
model WarehouseVoiceLog {
  id          String   @id @default(cuid())
  tenantId    String
  transcript  String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

/// Schede fiscali interne (entrata/cassa) finché non c’è integrazione RT — registro amministrativo per tenant.
model ArchivioFiscalStub {
  id           String   @id @default(cuid())
  tenantId     String
  kind         String
  reference    String   @default("")
  counterparty String   @default("")
  issueDate    DateTime @default(now())
  amount       Decimal  @db.Decimal(12, 2) @default(0)
  vatRateNote  String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind, createdAt])
}

/// Notifiche in-app per gli utenti del tenant.
model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  type      String   @default("sistema")
  title     String
  message   String   @default("")
  href      String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, read, createdAt])
  @@index([tenantId, createdAt])
}

/// Catalogo voci del servizio in camera (configurabile dall'hotel manager).
model RoomServiceCatalogItem {
  id         String              @id @default(cuid())
  tenantId   String
  name       String
  category   RoomServiceCategory
  unitPrice  Decimal             @db.Decimal(10, 2)
  unit       String              @default("pz")
  active     Boolean             @default(true)
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@index([tenantId, active])
}

/// Ordine di servizio in camera: food, lavanderia, minibar, pulizia scarpe, ecc.
model RoomServiceOrder {
  id             String              @id @default(cuid())
  tenantId       String
  stayId         String?
  folioId        String?
  roomCode       String
  guestName      String
  category       RoomServiceCategory
  status         RoomServiceStatus   @default(pending)
  items          Json
  total          Decimal             @db.Decimal(10, 2)
  notes          String              @default("")
  assignedTo     String?
  requestedAt    DateTime            @default(now())
  deliveredAt    DateTime?
  chargedToFolio Boolean             @default(false)
  folioChargeId  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, requestedAt])
  @@index([tenantId, roomCode])
  @@index([tenantId, assignedTo, status])
}
