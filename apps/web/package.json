{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "e2e": "playwright test",
    "postinstall": "prisma generate",
    "db:test:connection": "node scripts/test-db-connection.mjs",
    "db:cleanup-celeste": "node scripts/cleanup-celeste-targets.mjs",
    "db:migrate:rate-limit": "node scripts/apply-rate-limit-migration.mjs",
    "db:migrate:pending": "node scripts/apply-pending-migrations.mjs",
    "db:apply:sql": "node scripts/apply-sql-file.mjs",
    "db:apply:storni-voice-fiscal": "node scripts/apply-storni-voice-fiscal-sql.mjs",
    "db:verify:storni-voice-fiscal": "node scripts/verify-storni-voice-fiscal.mjs",
    "db:migrate:purchase-orders": "node scripts/apply-purchase-orders-migration.mjs",
    "db:migrate:warehouse-locations": "node scripts/apply-warehouse-locations-migration.mjs",
    "db:migrate:operational-notes": "node scripts/apply-operational-notes-migration.mjs",
    "db:migrate:shift-plans": "node scripts/apply-shift-plans-migration.mjs",
    "db:create-superadmin": "node scripts/create-superadmin.mjs",
    "db:sanity": "node scripts/db-sanity-check.mjs",
    "db:check-tables": "node scripts/db-check-tables.mjs",
    "db:seed-tables": "node scripts/seed-default-tables.mjs",
    "db:seed-tables:execute": "node scripts/seed-default-tables.mjs --execute",
    "db:ensure-tenant-defaults": "tsx scripts/ensure-tenant-defaults.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.4.49",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
